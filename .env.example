# Copy to .env and fill in — .env is gitignored, keep it that way.

# Supabase (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# n8n webhook base — turns the AI writer + companion "alive"
# e.g. https://n8n.lumenai.sbs/webhook
VITE_N8N_WEBHOOK_BASE=

# Optional: direct Anthropic key (demo only — production goes through n8n)
VITE_ANTHROPIC_API_KEY=
